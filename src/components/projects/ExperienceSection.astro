---
import { getExperiences } from "@/lib/notion-fetch";

const PREVIEW = 3;
const experiences = await getExperiences();

const preview = experiences.map((exp) => {
  const start = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(exp.startDate);
  const end = exp.endDate ? new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(exp.endDate) : 'Present';

  return {
    ...exp,
    start,
    end,
  };
}).slice(0, PREVIEW);
---

<section class="section" data-fade>
  <div class="section-header">
    <div class="section-title">
      <span class="label">Experience</span>
      <span class="count">{experiences.length}</span>
    </div>
    <a href="/projects/experience/1" class="view-all">View all →</a>
  </div>

  <div class="cards-row">
    {
      preview.map((exp) => (
        <div class="card">
          <div class="card-top">
            <div class="card-logo-wrap">
              {exp.logo ? (
                <img
                  src={exp.logo}
                  alt={exp.company}
                  class="card-logo"
                  loading="lazy"
                />
              ) : (
                <span class="card-logo-placeholder">{exp.company[0]}</span>
              )}
            </div>
            <div>
              <p class="card-title">{exp.title}</p>
              <p class="card-company">
                {exp.company} · {exp.type}
              </p>
            </div>
          </div>
          <div class="card-bottom">
            <p class="card-meta">
              {exp.start} – {exp.end} · {exp.duration}
            </p>
            {exp.location && <p class="card-meta">{exp.location}</p>}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section {
    margin-bottom: 3rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }
  .count {
    font-size: 0.65rem;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: 1px 7px;
    border-radius: 10px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }
  .view-all {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .view-all:hover {
    color: var(--color-text);
  }
  .cards-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 700px) {
    .cards-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .cards-row {
      grid-template-columns: 1fr;
    }
  }
  .card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px 16px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
    transition: border-color 0.15s;
  }
  .card:hover {
    border-color: var(--color-border-strong);
  }
  .card-top {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .card-logo-wrap {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 7px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .card-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-logo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    background: var(--color-bg-subtle);
  }
  .card-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .card-company {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }
  .card-bottom {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .card-meta {
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    line-height: 1.4;
  }
</style>
