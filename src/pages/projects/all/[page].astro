---
import PageLayout from '@/layouts/PageLayout.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { getProjects } from '@/lib/notion-fetch';
import type { Project } from '@/types/index';

const PER_PAGE = 9;

export async function getStaticPaths() {
  const PER_PAGE = 9;
  const all = await getProjects();
  const totalPages = Math.max(1, Math.ceil(all.length / PER_PAGE));
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: {
      items: all.slice(i * PER_PAGE, (i + 1) * PER_PAGE),
      currentPage: i + 1,
      totalPages,
    },
  }));
}

interface Props {
  items: Project[];
  currentPage: number;
  totalPages: number;
}

const { items, currentPage, totalPages } = Astro.props;
---

<PageLayout title="Projects | Caio Theodoro" description="All projects." wide>
  <div class="page-nav">
    <a href="/projects" class="back">← Professional / Projects</a>
  </div>
  <PageHeader title="Projects" />

  <div class="grid">
    {items.map((item) => (
      <div class="card">
        <div class="card-top">
          <p class="card-name">{item.name}</p>
          <p class="card-desc">{item.description}</p>
        </div>
        <div class="card-bottom">
          <div class="tags">
            {item.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <div class="links">
            {item.github && (
              <a href={item.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              </a>
            )}
            {item.link && (
              <a href={item.link} target="_blank" rel="noopener noreferrer" aria-label="External link" class="link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  {totalPages > 1 && (
    <div class="pagination">
      {currentPage > 1
        ? <a href={`/projects/all/${currentPage - 1}`} class="page-btn">← Previous</a>
        : <span class="page-btn disabled">← Previous</span>
      }
      <span class="page-info">{currentPage} / {totalPages}</span>
      {currentPage < totalPages
        ? <a href={`/projects/all/${currentPage + 1}`} class="page-btn">Next →</a>
        : <span class="page-btn disabled">Next →</span>
      }
    </div>
  )}
</PageLayout>

<style>
  .page-nav {
    margin-bottom: 1.5rem;
  }
  .back {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back:hover {
    color: var(--color-text);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 2rem;
  }
  .card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px 16px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
    transition: border-color 0.15s;
  }
  .card:hover {
    border-color: var(--color-border-strong);
  }
  .card-top {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .card-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .tag {
    font-size: 0.65rem;
    padding: 2px 7px;
    border-radius: 6px;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .links {
    display: flex;
    gap: 6px;
  }
  .link-icon {
    color: var(--color-text-tertiary);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .link-icon:hover {
    color: var(--color-text);
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .page-btn {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .page-btn:not(.disabled):hover {
    color: var(--color-text);
  }
  .page-btn.disabled {
    color: var(--color-text-tertiary);
    cursor: default;
  }
  .page-info {
    font-size: 0.72rem;
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
  }
</style>
