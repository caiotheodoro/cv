---
interface Props {
  description: string;
  subdescription: string;
}

const { description, subdescription } = Astro.props;
---

<div class="hero" data-fade data-delay="1">
  <h1 class="hero-heading">
    Hi there<span class="dot">👋</span>
  </h1>

  <div class="hero-body">
    <p>{description}</p>
    {
      subdescription && (
        <>
          <p>{subdescription}</p>
          <div class="social-row">
            <a
              href="https://github.com/caiotheodoro"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="gh"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/caiotheodoro1/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="li"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect x="2" y="9" width="4" height="12" />
                  <circle cx="4" cy="4" r="2" />
                </>
              </svg>
            </a>
          </div>
        </>
      )
    }
  </div>
</div>

<style>
  .hero {
    padding-top: 2rem;
    margin-bottom: 0;
  }
  .hero-heading {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 3rem;
  }
  .dot {
    color: var(--color-accent);
  }
  .hero-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 580px;
  }
  p {
    font-size: 1.075rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .social-row {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 2rem;
  }
  .social-row a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: opacity 0.15s;
  }
  .social-row a:hover {
    opacity: 0.6;
  }
  .social-row .gh {
    color: #000;
  }
  .social-row .li {
    color: #0a66c2;
  }
</style>
