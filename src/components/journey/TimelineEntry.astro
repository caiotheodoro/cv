---
interface Props {
  id: string;
  title: string;
  description: string;
  imageUrl?: string;
  isFirst?: boolean;
}

const { id, title, description, imageUrl, isFirst = false } = Astro.props;
---

<div
  class="timeline-entry"
  id={`entry-${id}`}
  data-active={isFirst ? 'true' : 'false'}
  style="position: relative; padding-left: 20px;"
>
  <!-- Dot -->
  <div
    class="timeline-dot"
    style="
      position: absolute;
      left: -29px;
      top: 7px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      border: 2px solid white;
      z-index: 1;
    "
  />

  <!-- Title (always visible) -->
  <div style="
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: 6px;
    cursor: default;
  ">
    {title}
  </div>

  <!-- Expandable content -->
  <div class="timeline-entry-content">
    <div>
      {description && (
        <div
          class="entry-desc"
          style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.65; margin-bottom: 10px;"
          set:html={description}
        />
      )}
      {imageUrl && (
        <div style="border-radius: 8px; overflow: hidden; border: 1px solid var(--color-border); max-width: 320px; margin-top: 10px;">
          <img
            src={imageUrl}
            alt={title}
            loading="lazy"
            style="width: 100%; height: auto; display: block;"
          />
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .entry-desc :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .entry-desc :global(a:hover) {
    border-color: var(--color-accent);
  }
</style>
