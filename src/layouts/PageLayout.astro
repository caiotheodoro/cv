---
import BaseLayout from './BaseLayout.astro';
import Dock from '@/components/layout/Dock.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  wide?: boolean;
}

const { title, description, image, wide = false } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <a href="/" class="identity" aria-label="Caio Theodoro — home">
    <img
      src="https://github.com/caiotheodoro.png"
      alt="Caio Theodoro"
      width="28"
      height="28"
    />
    <span>Caio Theodoro</span>
  </a>

  <main style={`max-width: ${wide ? '960px' : '680px'}; margin: 0 auto; padding: clamp(2.5rem, 8vh, 5rem) 1.5rem 6rem;`}>
    <slot />
  </main>

  <Dock currentPath={Astro.url.pathname} />
</BaseLayout>

<style>
  .identity {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--color-text);
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .identity:hover {
    opacity: 1;
  }
  .identity img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    display: block;
  }
  .identity span {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
</style>
