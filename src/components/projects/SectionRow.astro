---
import type { Project, Certification, Notebook } from '@/types/index';

type ItemType = 'project' | 'certification' | 'notebook';

interface Props {
  title: string;
  href: string;
  items: (Project | Certification | Notebook)[];
  total: number;
  type: ItemType;
}

const { title, href, items, total, type } = Astro.props;

const issuerColors: Record<string, { text: string; border: string }> = {
  AWS: { text: '#C47600', border: '#FF990033' },
  IBM: { text: '#1F70C1', border: '#1F70C133' },
  Google: { text: '#C5221F', border: '#EA433533' },
};
---

<section class="section" data-fade>
  <div class="section-header">
    <div class="section-title">
      <span class="label">{title}</span>
      <span class="count">{total}</span>
    </div>
    <a href={href} class="view-all">View all →</a>
  </div>

  <div class="cards-row">
    {type === 'project' && (items as Project[]).map((item) => (
      <div class="card">
        <div class="card-top">
          <p class="card-name">{item.name}</p>
          <p class="card-desc">{item.description}</p>
        </div>
        <div class="card-bottom">
          <div class="tags">
            {item.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <div class="links">
            {item.github && (
              <a href={item.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              </a>
            )}
            {item.link && (
              <a href={item.link} target="_blank" rel="noopener noreferrer" aria-label="External link" class="link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>
    ))}

    {type === 'certification' && (items as Certification[]).map((item) => (
      <div class="card">
        <div class="card-top">
          <span
            class="issuer-badge"
            style={`color: ${issuerColors[item.issuer]?.text ?? '#666'}; border-color: ${issuerColors[item.issuer]?.border ?? '#ccc'}`}
          >{item.issuer}</span>
          <p class="card-name">{item.name}</p>
          {item.credentialId && <p class="credential-id">{item.credentialId}</p>}
        </div>
        <div class="card-bottom">
          <span />
          {item.link && (
            <a href={item.link} target="_blank" rel="noopener noreferrer" aria-label="View certificate" class="link-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          )}
        </div>
      </div>
    ))}

    {type === 'notebook' && (items as Notebook[]).map((item) => (
      <div class="card">
        <div class="card-top">
          <p class="card-name">{item.name}</p>
          <p class="card-desc">{item.description}</p>
        </div>
        <div class="card-bottom">
          <span />
          <a href={item.link} target="_blank" rel="noopener noreferrer" aria-label="View notebook" class="link-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section {
    margin-bottom: 3rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }
  .count {
    font-size: 0.65rem;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: 1px 7px;
    border-radius: 10px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }
  .view-all {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .view-all:hover {
    color: var(--color-text);
  }
  .cards-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 700px) {
    .cards-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .cards-row {
      grid-template-columns: 1fr;
    }
  }
  .card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px 16px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
    transition: border-color 0.15s;
  }
  .card:hover {
    border-color: var(--color-border-strong);
  }
  .card-top {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .card-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }
  .card-desc {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .tag {
    font-size: 0.65rem;
    padding: 2px 7px;
    border-radius: 6px;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  .links {
    display: flex;
    gap: 6px;
  }
  .link-icon {
    color: var(--color-text-tertiary);
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .link-icon:hover {
    color: var(--color-text);
  }
  .issuer-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border-radius: 6px;
    border: 1px solid;
    background: transparent;
    display: inline-block;
    width: fit-content;
  }
  .credential-id {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.04em;
  }
</style>
